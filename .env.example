# ============================================================
# CodeVault Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Django Core
SECRET_KEY=django-insecure-change-this-in-production-use-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database (PostgreSQL) ----------------------------------
DATABASE_URL=postgresql://codevault:codevault_pass@localhost:5432/codevault

# ---- Redis / Celery ----------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Neo4j -------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=codevault_pass

# ---- ChromaDB ----------------------------------------------
# Path where ChromaDB will store vector embeddings on disk
CHROMA_DB_PATH=./chroma_db_data

# ---- LLM API Keys (configure at least one) -----------------
# The system will use whichever key is set (OpenAI > Anthropic > Google)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- CORS ---------------------------------------------------
# Set to False in production and list specific origins
CORS_ALLOW_ALL_ORIGINS=True
